# Testing Guidelines

## Overview

Testing in Ora Browser follows Swift testing conventions and covers unit tests, integration tests, and UI testing. Test files are organized in the `oraTests/` and `oraUITests/` directories.

## Testing Structure

### 1. Unit Tests (`oraTests/`)
- Test individual classes and functions
- Mock dependencies for isolation
- Test business logic and data transformations
- Validate model behavior and constraints

### 2. UI Tests (`oraUITests/`)
- Test user workflows and interactions
- Validate UI behavior and navigation
- Test integration between components
- Simulate user actions and gestures

## Testing Patterns

### 1. Service Testing
Test service classes with mocked dependencies:
```swift
class TabManagerTests: XCTestCase {
    var tabManager: TabManager!
    var mockContainer: ModelContainer!
    var mockContext: ModelContext!

    override func setUp() {
        super.setUp()
        // Setup mocks and test data
        mockContainer = setupMockContainer()
        mockContext = ModelContext(mockContainer)
        tabManager = TabManager(
            modelContainer: mockContainer,
            modelContext: mockContext,
            mediaController: MockMediaController()
        )
    }

    func testTabCreation() {
        let container = TabContainer(name: "Test", emoji: "🧪")
        mockContext.insert(container)

        let tab = tabManager.addTab(
            title: "Test Tab",
            url: URL(string: "https://example.com")!,
            container: container,
            isPrivate: false
        )

        XCTAssertNotNil(tab.id)
        XCTAssertEqual(tab.title, "Test Tab")
        XCTAssertEqual(tab.url.absoluteString, "https://example.com")
    }

    func testTabSwitching() {
        let tab1 = createTestTab(title: "Tab 1")
        let tab2 = createTestTab(title: "Tab 2")

        tabManager.activateTab(tab2)

        XCTAssertEqual(tabManager.activeTab?.id, tab2.id)
        XCTAssertEqual(tab2.maybeIsActive, true)
    }
}
```

### 2. Model Testing
Test SwiftData models and relationships:
```swift
class TabModelTests: XCTestCase {
    var container: ModelContainer!
    var context: ModelContext!

    override func setUp() {
        super.setUp()
        container = setupInMemoryContainer()
        context = ModelContext(container)
    }

    func testTabCreation() {
        let testContainer = TabContainer(name: "Test", emoji: "🧪")
        context.insert(testContainer)

        let tab = Tab(
            url: URL(string: "https://example.com")!,
            title: "Test",
            container: testContainer,
            tabManager: MockTabManager(),
            isPrivate: false
        )
        context.insert(tab)

        XCTAssertNotNil(tab.id)
        XCTAssertEqual(tab.container.id, testContainer.id)
    }

    func testTabRelationships() {
        let container = TabContainer(name: "Work", emoji: "💼")
        context.insert(container)

        let tab1 = Tab(
            url: URL(string: "https://example1.com")!,
            title: "Tab 1",
            container: container,
            tabManager: MockTabManager(),
            isPrivate: false
        )
        context.insert(tab1)

        let tab2 = Tab(
            url: URL(string: "https://example2.com")!,
            title: "Tab 2",
            container: container,
            tabManager: MockTabManager(),
            isPrivate: false
        )
        context.insert(tab2)

        let fetchedTabs = try! context.fetch(
            FetchDescriptor<Tab>(predicate: #Predicate { $0.container.id == container.id })
        )

        XCTAssertEqual(fetchedTabs.count, 2)
    }
}
```

